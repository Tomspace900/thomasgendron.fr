# Clé API Gemini — https://aistudio.google.com/apikey
# JAMAIS commitée, JAMAIS côté client. À renseigner aussi dans Vercel.
GEMINI_API_KEY=

# Pré-prompt de la section « Pourquoi me recruter ? » (rédigé par Thomas).
# Sans cette variable, un prompt de développement générique est utilisé.
HIRE_ME_SYSTEM_PROMPT=

# Optionnel — modèle Gemini (défaut : gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash
